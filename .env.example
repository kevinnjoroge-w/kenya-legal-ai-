# =============================================================================
# Kenya Legal AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# LLM Provider (choose one or multiple)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=your-groq-api-key-here
COHERE_API_KEY=your-cohere-api-key-here

# Model configuration
LLM_PROVIDER=groq                      # openai | anthropic | ollama | google | groq
LLM_MODEL=llama-3.3-70b-versatile      # llama-3.3-70b-versatile | gpt-4o
LLM_TEMPERATURE=0.4
DRAFTING_TEMPERATURE=0.2

# Embedding configuration
EMBEDDING_PROVIDER=cohere              # openai | google | cohere | huggingface
EMBEDDING_MODEL=embed-english-v3.0     # embed-english-v3.0 or embed-multilingual-v3.0
EMBEDDING_DIMENSION=1024               # 1024 for cohere

# -----------------------------------------------------------------------------
# Data Sources
# -----------------------------------------------------------------------------
LAWS_AFRICA_API_KEY=your-laws-africa-api-key
LAWS_AFRICA_BASE_URL=https://api.laws.africa/v3

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kenya_legal_docs
# QDRANT_API_KEY=your-qdrant-cloud-key  # Only for Qdrant Cloud
QDRANT_CLOUD_HOST=
QDRANT_CLOUD_API_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/kenya_legal_ai

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Kenya Legal AI"
APP_ENV=development                    # development | staging | production
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# Data Storage
# -----------------------------------------------------------------------------
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
METADATA_DIR=data/metadata
